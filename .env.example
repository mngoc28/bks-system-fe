VITE_URL=https://api-bks.golineglobal.vn/api/v1
VITE_IMAGES_URL=https://api-bks.golineglobal.vn

# Realtime (Partner Portal 360 Phase 2)
# - Soketi local:   VITE_PUSHER_HOST=127.0.0.1, VITE_PUSHER_PORT=6001, VITE_PUSHER_SCHEME=http
# - Pusher Cloud:   để VITE_PUSHER_HOST trống, VITE_PUSHER_PORT=443, VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_KEY=local-key
VITE_PUSHER_APP_CLUSTER=mt1
VITE_PUSHER_HOST=127.0.0.1
VITE_PUSHER_PORT=6001
VITE_PUSHER_SCHEME=http

# Feature flag — set false để tắt realtime + chỉ dùng polling/refetch.
VITE_PARTNER_REALTIME=true
VITE_CLOUDINARY_VIDEO_URL=https://res.cloudinary.com/dc2ivo5ez/video/upload
VITE_ENABLE_CHATBOT=true

